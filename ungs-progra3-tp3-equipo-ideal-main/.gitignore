# ==========================================
# Compilados de Java y Salidas de IDEs
# ==========================================
*.class
*.log

# Carpetas donde Eclipse/Maven guardan los binarios compilados localmente
bin/
target/
out/

# ==========================================
# Configuraciones específicas de Eclipse (¡MUY IMPORTANTE!)
# ==========================================
.metadata/
.settings/
.project
.classpath

# Si alguien en el grupo usa IntelliJ por error o VS Code
.idea/
*.iml
.vscode/

# ==========================================
# Otros entornos (BlueJ, Mobile, etc.)
# ==========================================
*.ctxt
.mtj.tmp/

# ==========================================
# Archivos empaquetados y pesados
# ==========================================
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Logs de error catastróficos de la máquina virtual de Java
hs_err_pid*
replay_pid*